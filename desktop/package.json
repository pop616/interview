{
  "name": "interview-desktop",
  "version": "1.0.0",
  "description": "Десктопное приложение для работников",
  "homepage": "./",
  "main": "public/electron.js",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
